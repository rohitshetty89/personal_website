{
  "name": "my-website",
  "version": "1.0.0",
  "private": true,
  "description": "React frontend with Kotlin backend deployed on AWS",
  "scripts": {
    "build:frontend": "npm run build --workspace=frontend",
    "build:infra": "npm run build --workspace=infra",
    "deploy": "npm run deploy --workspace=infra",
    "synth": "npm run synth --workspace=infra",
    "test": "npm run test --workspaces --if-present"
  },
  "workspaces": [
    "frontend",
    "infra"
  ]
}
